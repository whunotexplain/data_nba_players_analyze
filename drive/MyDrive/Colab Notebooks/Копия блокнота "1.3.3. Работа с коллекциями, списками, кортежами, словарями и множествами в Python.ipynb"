:{"colab":{"base_uri":"https://localhost:8080/"},"id":"q-NZ4xqjUV-X","executionInfo":{"status":"ok","timestamp":1762359021080,"user_tz":-420,"elapsed":6,"user":{"displayName":"Павел Пересунько","userId":"04177230109244878208"}},"outputId":"f3df56a5-d8df-424c-b54a-941bb3f0e9be"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Ключ: a, Значение: 1\n","Ключ: b, Значение: 2\n","Ключ: c, Значение: 3\n"]}]},{"cell_type":"markdown","source":["### Базовое использование `max` с словарями"],"metadata":{"id":"mmGXjntXWPDV"}},{"cell_type":"code","source":["my_dict = {'b': 2, 'a': 5, 'c': 1}\n","\n","# По умолчанию max() работает с ключами\n","result = max(my_dict)\n","print(result)  # 'c' (последний в алфавитном порядке)\n","\n","# Эквивалентно:\n","result = max(my_dict.keys())\n","print(result)  # 'c'"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"7bGBInm3WPmt","executionInfo":{"status":"ok","timestamp":1762359684900,"user_tz":-420,"elapsed":53,"user":{"displayName":"Павел Пересунько","userId":"04177230109244878208"}},"outputId":"2eb04338-b52c-4545-e13f-6179437f9b01"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["c\n","c\n"]}]},{"cell_type":"markdown","source":["Поиск максимального по значениям"],"metadata":{"id":"lV2ZEm_7Wav3"}},{"cell_type":"code","source":["my_dict = {'a': 10, 'b': 25, 'c': 5}\n","\n","# Ключ с максимальным значением\n","max_key = max(my_dict, key=my_dict.get)\n","print(f\"Ключ с максимальным значением: {max_key}\")  # b\n","\n","# Полная информация\n","max_key = max(my_dict, key=my_dict.get)\n","max_value = my_dict[max_key]\n","print(f\"Ключ: {max_key}, Значение: {max_value}\")  # Ключ: b, Значение: 25"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ijrK7VpRWgMI","executionInfo":{"status":"ok","timestamp":1762359741151,"user_tz":-420,"elapsed":53,"user":{"displayName":"Павел Пересунько","userId":"04177230109244878208"}},"outputId":"9024e6ac-975f-4