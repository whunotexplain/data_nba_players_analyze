 точных результатов нужно много испытаний\n"]}]},{"cell_type":"markdown","source":["# Задание 1 в тренажере"],"metadata":{"id":"i7p5wQs0AAVx"}},{"cell_type":"markdown","source":["Написать функцию `roll_dice()`, которая возвращает целое случайное число от 1 до 6. Для генерации случайного числа использовать функцию `random.randint()`.\n","\n","Сделать функцию print_result, которая принимает на вход число и печатает строку вида: \"Случайное число - {аргумент_функции}\", где {аргумент_функции} - значение аргумента функции"],"metadata":{"id":"T4Kmhovz_srz"}},{"cell_type":"markdown","source":["# Теорема сложения: P(A∪B) = P(A) + P(B) - P(A∩B)"],"metadata":{"id":"y7X0Fj_aZ7V1"}},{"cell_type":"code","source":["# ==================== ВЕРОЯТНОСТЬ: ЧИСЛО ЧЕТНОЕ ИЛИ МЕНЬШЕ 3 ====================\n","\n","print(\"🎯 ВЕРОЯТНОСТЬ: ЧИСЛО ЧЕТНОЕ ИЛИ МЕНЬШЕ 3 НА КУБИКЕ\")\n","print(\"=\" * 55)\n","\n","# Определяем события\n","print(\"\\n📊 ОПРЕДЕЛЕНИЕ СОБЫТИЙ:\")\n","print(\"Событие A: число четное → {2, 4, 6}\")\n","print(\"Событие B: число < 3 → {1, 2}\")\n","print(\"Нас интересует: P(A ∪ B) (A ИЛИ B)\")\n","\n","# Теоретический расчет\n","A = {2, 4, 6}  # Четные числа\n","B = {1, 2}     # Числа < 3\n","\n","A_union_B = A.union(B)  # Объединение\n","A_intersect_B = A.intersection(B)  # Пересечение\n","\n","print(f\"\\nA ∪ B = {A} ∪ {B} = {A_union_B}\")\n","print(f\"A ∩ B = {A} ∩ {B} = {A_intersect_B}\")\n","\n","# Вероятности\n","P_A = len(A) / 6\n","P_B = len(B) / 6\n","P_A_intersect_B = len(A_intersect_B) / 6\n","P_A_union_B_theory = P_A + P_B - P_A_intersect_B\n","\n","print(f\"\\n📈 ТЕОРЕТИЧЕСКИЙ РАСЧЕТ:\")\n","print(f\"P(A) = {len(A)}/6 = {P_A:.3f}\")\n","print(f\"P(B) = {len(B)}/6 = {P_B:.3f}\")\n","print(f\"P(A ∩ B) = {len(A_intersect_B)}/6 = {P_A_intersect_B:.3f}\")\n","print(f\"P(A ∪ B) = P(A) + P(B) - P(A ∩ B) = {P_A:.3f} + {P_B:.3f} - {P_A_intersect_B:.3f} = {P_A_union_B_theory:.3f}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Z-CNz4WXqMO9","executionInfo":{"status":"ok","timestamp":1774694595376,"user_tz":-180,"elapsed":31,"user":{"displayName":"BigBüddÿGücciBürgër","userId":"14846318119290605284"}},"outputId":"d192afdb-7764-4629-aece-180cfda4b384"},"execution_count":15,"outputs":[{"output_type":"stream","name":"stdout","text":["🎯 ВЕРОЯТНОСТЬ: ЧИСЛО ЧЕТНОЕ ИЛИ МЕНЬШЕ 3 НА КУБИКЕ\n","=======================================================\n","\n","📊 ОПРЕДЕЛЕНИЕ СОБЫТИЙ:\n","Событие A: число четное → {2, 4, 6}\n","Событие B: число < 3 → {1, 2}\n","Нас интересует: P(A ∪ B) (A ИЛИ B)\n","\n","A ∪ B = {2, 4, 6} ∪ {1, 2} = {1, 2, 4, 6}\n","A ∩ B = {2, 4, 6} ∩ {1, 2} = {2}\n","\n","📈 ТЕОРЕТИЧЕСКИЙ РАСЧЕТ:\n","P(A) = 3/6 = 0.500\n","P(B) = 2/6 = 0.333\n","P(A ∩ B) = 1/6 = 0.167\n","P(A ∪ B) = P(A) + P(B) - P(A ∩ B) = 0.500 + 0.333 - 0.167 = 0.667\n"]}]},{"cell_type":"code","source":["# ==================== ЭКСПЕРИМЕНТАЛЬНАЯ ПРОВЕРКА ====================\n","\n","print(\"\\n🎲 ЭКСПЕРИМЕНТАЛЬНАЯ ПРОВЕРКА:\")\n","print(\"-\" * 35)\n","\n","# Проводим эксперименты с разным количеством бросков\n","experiments = [10, 100, 1000, 10_000, 100_000, 1_000_000]\n","\n","results = []\n","\n","for num_rolls in experiments:\n","    # Бросаем кубик\n","    rolls = np.random.randint(1, 7, num_rolls)\n","\n","    # Считаем события\n","    count_A = np.sum((rolls % 2 == 0))  # Четные\n","    count_B = np.sum((rolls < 3))       # Меньше 3\n","    count_A_and_B = np.sum((rolls % 2 == 0) & (rolls < 3))  # Одновременно четные И меньше 3\n","    count_A_or_B = np.sum((rolls % 2 == 0) | (rolls < 3))   # Четные ИЛИ меньше 3\n","\n","    P_A_exp = count_A / num_rolls\n","    P_B_exp = count_B / num_rolls\n","    P_A_and_B_exp = count_A_and_B / num_rolls\n","    P_A_or_B_exp = count_A_or_B / num_rolls\n","    P_A_union_B_calculated = P_A_exp + P_B_exp - P_A_and_B_exp\n","\n","    results.append({\n","        'rolls': num_rolls,\n","        'P_A_exp': P_A_exp,\n","        'P_B_exp': P_B_exp,\n","        'P_A_and_B_exp': P_A_and_B_exp,\n","        'P_A_union_B_calculated': P_A_union_B_calculated,\n","        'P_A_or_B_exp': P_A_or_B_exp,\n","        'difference': abs(P_A_union_B_calculated - P_A_union_B_theory)\n","    })\n","\n","    print(f\"Бросков: {num_rolls:4d}\")\n","    print(f\"  P(A) эксп. = {P_A_exp:.3f}, P(B) эксп. = {P_B_exp:.3f}\")\n","    print(f\"  P(A∩B) эксп. = {P_A_and_B_exp:.3f}\")\n","    print(f\"  P(A)+P(B)-P(A∩B) (по формуле полной вероятности) = {P_A_union_B_calculated:.3f}\")\n","    print(f\"  P(A)+P(B)-P(A∩B) = {P_A_or_B_exp:.3f}\")\n","    print(f\"  Ошибка: {abs(P_A_union_B_calculated - P_A_union_B_theory):.3f}\")\n","    print()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Z8mwnnoJaBcb","executionInfo":{"status":"ok","timestamp":1774694595386,"user_tz":-180,"elapsed":7,"user":{"displayName":"BigBüddÿGücciBürgër","userId":"14846318119290605284"}},"outputId":"df168155-aa3c-43c4-9c02-f1d99b4a2aef"},"execution_count":16,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","🎲 ЭКСПЕРИМЕНТАЛЬНАЯ ПРОВЕРКА:\n","-----------------------------------\n","Бросков:   10\n","  P(A) эксп. = 0.100, P(B) эксп. = 0.200\n","  P(A∩B) эксп. = 0.000\n","  P(A)+P(B)-P(A∩B) (по формуле полной вероятности) = 0.300\n","  P(A)+P(B)-P(A∩B) = 0.300\n","  Ошибка: 0.367\n","\n","Бросков:  100\n","  P(A) эксп. = 0.460, P(B) эксп. = 0.340\n","  P(A∩B) эксп. = 0.190\n","  P(A)+P(B)-P(A∩B) (по формуле полной вероятности) = 0.610\n","  P(A)+P(B)-P(A∩B) = 0.610\n","  Ошибка: 0.057\n","\n","Бросков: 1000\n","  P(A) эксп. = 0.500, P(B) эксп. = 0.349\n","  P(A∩B) эксп. = 0.180\n","  P(A)+P(B)-P(A∩B) (по формуле полной вероятности) = 0.669\n","  P(A)+P(B)-P(A∩B) = 0.669\n","  Ошибка: 0.002\n","\n","Бросков: 10000\n","  P(A) эксп. = 0.497, P(B) эксп. = 0.335\n","  P(A∩B) эксп. = 0.168\n","  P(A)+P(B)-P(A∩B) (по формуле полной вероятности) = 0.663\n","  P(A)+P(B)-P(A∩B) = 0.663\n","  Ошибка: 0.003\n","\n","Бросков: 100000\n","  P(A) эксп. = 0.501, P(B) эксп. = 0.335\n","  P(A∩B) эксп. = 0.167\n","  P(A)+P(B)-P(A∩B) (по формуле полной вероятности) = 0.668\n","  P(A)+P(B)-P(A∩B) = 0.668\n","  Ошибка: 0.001\n","\n","Бросков: 1000000\n","  P(A) эксп. = 0.501, P(B) эксп. = 0.333\n","  P(A∩B) эксп. = 0.167\n","  P(A)+P(B)-P(A∩B) (по формуле полной вероятности) = 0.667\n","  P(A)+P(B)-P(A∩B) = 0.667\n","  Ошибка: 0.000\n","\n"]}]},{"cell_type":"code","source":["# ==================== ВИЗУАЛИЗАЦИЯ РЕЗУЛЬТАТОВ ====================\n","\n","plt.figure(figsize=(10, 4))\n","\n","# Сравнение экспериментальной и расчетной вероятности\n","rolls_counts = [exp['rolls'] for exp in results]\n","calc_probs = [exp['P_A_union_B_calculated'] for exp in results]\n","\n","plt.plot(rolls_counts, calc_probs, 'ro-', label='Эксперементальная P(A)+P(B)-P(A∩B)', linewidth=2, markersize=6)\n","plt.axhline(y=P_A_union_B_theory, color='green', linestyle='--', label='Теоретическая', linewidth=2)\n","plt.xscale('log')\n","plt.xlabel('Количество бросков')\n","plt.ylabel('Вероятность')\n","plt.title('Сравнение методов расчета P(A∪B)')\n","plt.legend()\n","plt.grid(True, alpha=0.3)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":415},"id":"Zmitd94N4tcN","executionInfo":{"status":"ok","timestamp":1774694595710,"user_tz":-180,"elapsed":321,"user":{"displayName":"BigBüddÿGücciBürgër","userId":"14846318119290605284"}},"outputId":"759ec3af-50cc-45fd-e16f-f04264e2552c"},"execution_count":17,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x400 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["# Формула полной вероятности"],"metadata":{"id":"5L0DAN3T6DIx"}},{"cell_type":"markdown","source":["Формула полной вероятности — это инструмент, который позволяет найти вероятность события, когда мы не можем наблюдать его напрямую, но знаем, при каких условиях оно может произойти и с какой вероятностью.\n","\n","Представьте, что вы хотите узнать вероятность того, что случайный прохожий на улице носит очки. Вы не можете посчитать всех людей в городе, но можете разбить их на группы по возрасту и для каждой группы знать вероятность ношения очков."],"metadata":{"id":"-Invoadqo0-n"}},{"cell_type":"markdown","source":["Формула:\n","\n","P(A) = P(H₁) × P(A|H₁) + P(H₂) × P(A|H₂) + ... + P(Hₙ) × P(A|Hₙ)\n","\n","где:\n","\n","- P(A) — полная вероятность события A (то, что мы хотим найти)\n","\n","- H₁, H₂, ..., Hₙ — полная группа несовместных гипотез (сценариев)\n","\n","- P(Hᵢ) — вероятность гипотезы Hᵢ\n","\n","- P(A|Hᵢ) — условная вероятность события A при условии, что верна гипотеза Hᵢ"],"metadata":{"id":"IZa3dYbx6fPa"}},{"cell_type":"markdown","source":["**Ситуация**\n","\n","Два завода производят одинаковую продукцию\n","\n","Завод A производит 60% всей продукции, уровень брака — 2%\n","\n","Завод B производит 40% всей продукции, уровень брака — 3%\n","\n","Вопрос: какова вероятность того, что случайно выбранное изделие окажется бракованным?"],"metadata":{"id":"P-cVQSpY6y-z"}},{"cell_type":"markdown","source":["**Решение через формулу полной вероятности**\n","\n","Мы не знаем, с какого завода придет изделие, но можем рассмотреть все возможные сценарии:\n","\n","1. Сценарий 1: изделие с завода A\n","\n","- Вероятность этого сценария: P(Завод A) = 0.6\n","\n","- Вероятность брака при этом сценарии: P(Брак|Завод A) = 0.02\n","\n","- Вклад этого сценария: 0.6 × 0.02 = 0.012\n","\n","2. Сценарий 2: изделие с завода B\n","\n","- Вероятность этого сценария: P(Завод B) = 0.4\n","\n","- Вероятность брака при этом сценарии: P(Брак|Завод B) = 0.03\n","\n","- Вклад этого сценария: 0.4 × 0.03 = 0.012\n","\n","Общая вероятность брака:\n","P(Брак) = 0.012 + 0.012 = 0.024 (или 2.4%)"],"metadata":{"id":"_tlxduN47Ach"}},{"cell_type":"code","source":["print(\"🎯 ТЕОРЕТИЧЕСКИЙ РАСЧЕТ: ФОРМУЛА ПОЛНОЙ ВЕРОЯТНОСТИ\")\n","print(\"=\" * 60)\n","\n","# Условие задачи\n","print(\"\\n📋 УСЛОВИЕ ЗАДАЧИ:\")\n","print(\"Два завода производят одинаковые детали:\")\n","print(\"• Завод 1: производит 60% всей продукции, брак составляет 2%\")\n","print(\"• Завод 2: производит 40% всей продукции, брак составляет 3%\")\n","print(\"\\nНайти вероятность того, что случайно выбранная деталь окажется бракованной\")\n","\n","# Определение гипотез\n","print(\"\\n📊 ОПРЕДЕЛЕНИЕ ГИПОТЕЗ:\")\n","print(\"H₁ - деталь произведена на заводе 1\")\n","print(\"H₂ - деталь произведена на заводе 2\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"95ILJZUu7rN8","executionInfo":{"status":"ok","timestamp":1774694595722,"user_tz":-180,"elapsed":10,"user":{"displayName":"BigBüddÿGücciBürgër","userId":"14846318119290605284"}},"outputId":"3fdc9d08-93a8-42eb-a975-4f17803345c5"},"execution_count":18,"outputs":[{"output_type":"stream","name":"stdout","text":["🎯 ТЕОРЕТИЧЕСКИЙ РАСЧЕТ: ФОРМУЛА ПОЛНОЙ ВЕРОЯТНОСТИ\n","============================================================\n","\n","📋 УСЛОВИЕ ЗАДАЧИ:\n","Два завода производят одинаковые детали:\n","• Завод 1: производит 60% всей продукции, брак составляет 2%\n","• Завод 2: производит 40% всей продукции, брак составляет 3%\n","\n","Найти вероятность того, что случайно выбранная деталь окажется бракованной\n","\n","📊 ОПРЕДЕЛЕНИЕ ГИПОТЕЗ:\n","H₁ - деталь произведена на заводе 1\n","H₂ - деталь произведена на заводе 2\n"]}]},{"cell_type":"code","source":["# Вероятности гипотез\n","print(\"\\n🔢 ВЕРОЯТНОСТИ ГИПОТЕЗ:\")\n","P_H1 = 0.60\n","P_H2 = 0.40\n","print(f\"P(H₁) = {P_H1}\")\n","print(f\"P(H₂) = {P_H2}\")\n","print(f\"Проверка: P(H₁) + P(H₂) = {P_H1} + {P_H2} = {P_H1 + P_H2} ✓\")\n","\n","# Условные вероятности\n","print(\"\\n📈 УСЛОВНЫЕ ВЕРОЯТНОСТИ:\")\n","P_A_H1 = 0.02  # P(Брак|H₁)\n","P_A_H2 = 0.03  # P(Брак|H₂)\n","print(f\"P(Брак|H₁) = {P_A_H1}\")\n","print(f\"P(Брак|H₂) = {P_A_H2}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"E1bK9u-7o_YU","executionInfo":{"status":"ok","timestamp":1774694595736,"user_tz":-180,"elapsed":12,"user":{"displayName":"BigBüddÿGücciBürgër","userId":"14846318119290605284"}},"outputId":"69d49157-c48f-4cb6-eb80-69da7e119155"},"execution_count":19,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","🔢 ВЕРОЯТНОСТИ ГИПОТЕЗ:\n","P(H₁) = 0.6\n","P(H₂) = 0.4\n","Проверка: P(H₁) + P(H₂) = 0.6 + 0.4 = 1.0 ✓\n","\n","📈 УСЛОВНЫЕ ВЕРОЯТНОСТИ:\n","P(Брак|H₁) = 0.02\n","P(Брак|H₂) = 0.03\n"]}]},{"cell_type":"code","source":["# Формула полной вероятности\n","print(\"\\n🧮 ФОРМУЛА ПОЛНОЙ ВЕРОЯТНОСТИ:\")\n","print(\"P(A) = P(H₁) × P(A|H₁) + P(H₂) × P(A|H₂)\")\n","print(\"где A - событие 'деталь бракованная'\")\n","\n","print(\"\\n📝 ПОДСТАНОВКА ЗНАЧЕНИЙ:\")\n","print(f\"P(Брак) = P(H₁) × P(Брак|H₁) + P(H₂) × P(Брак|H₂)\")\n","print(f\"P(Брак) = {P_H1} × {P_A_H1} + {P_H2} × {P_A_H2}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"BIleMhv670um","executionInfo":{"status":"ok","timestamp":1774694595747,"user_tz":-180,"elapsed":9,"user":{"displayName":"BigBüddÿGücciBürgër","userId":"14846318119290605284"}},"outputId":"c00f9cc9-73f0-402b-98fc-08231d4844d9"},"execution_count":20,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","🧮 ФОРМУЛА ПОЛНОЙ ВЕРОЯТНОСТИ:\n","P(A) = P(H₁) × P(A|H₁) + P(H₂) × P(A|H₂)\n","где A - событие 'деталь бракованная'\n","\n","📝 ПОДСТАНОВКА ЗНАЧЕНИЙ:\n","P(Брак) = P(H₁) × P(Брак|H₁) + P(H₂) × P(Брак|H₂)\n","P(Брак) = 0.6 × 0.02 + 0.4 × 0.03\n"]}]},{"cell_type":"code","source":["# Пошаговый расчет\n","print(\"\\n🔍 ПОШАГОВЫЙ РАСЧЕТ:\")\n","\n","# Вклад завода 1\n","contribution_H1 = P_H1 * P_A_H1\n","print(f\"1. Вклад завода 1: P(H₁) × P(Брак|H₁) = {P_H1} × {P_A_H1} = {contribution_H1:.4f}\")\n","\n","# Вклад завода 2\n","contribution_H2 = P_H2 * P_A_H2\n","print(f\"2. Вклад завода 2: P(H₂) × P(Брак|H₂) = {P_H2} × {P_A_H2} = {contribution_H2:.4f}\")\n","\n","# Общая вероятность\n","P_A_total = contribution_H1 + contribution_H2\n","print(f\"3. Общая вероятность: {contribution_H1:.4f} + {contribution_H2:.4f} = {P_A_total:.4f}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"8LXdXqQj7xft"